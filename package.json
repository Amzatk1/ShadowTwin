{
  "name": "shadowtwin",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @shadowtwin/web",
    "dev:mobile": "npm run start --workspace @shadowtwin/mobile",
    "dev:api": "python apps/api/manage.py runserver 0.0.0.0:8000",
    "dev:worker": "python -m celery -A apps.worker.worker.celery_app worker -l info",
    "lint:web": "npm run lint --workspace @shadowtwin/web",
    "typecheck:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "typecheck:mobile": "tsc --noEmit -p apps/mobile/tsconfig.json"
  }
}
